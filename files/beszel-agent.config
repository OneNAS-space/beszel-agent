config beszel-agent 'main'
    option enable '0'
    option docker_host ''
    option listen '0.0.0.0:45876'
    option key ''
    option token ''
    option hub_url ''
    option log_level 'info'
    option system_name 'openwrt'
    option intel_gpu_device ''
    
