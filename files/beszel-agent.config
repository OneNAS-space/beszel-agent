config beszel-agent 'main'
    option enable '0'
    
    # Monitoring port: default 45876 (only needs to be opened in SSH mode, and needs to be defined but not exposed in WebSocket mode)
    option port '45876'
    
    # [Mode 1: SSH Mode] Public key generated by Hub
    # Format example: 'ssh-ed25519 AAAAC3NzaC1...'
    option key ''
    
    # [Mode 2: WebSocket Mode] (Recommended, open port-free)
    # Token and Hub URL must be filled in at the same time to activate the WebSocket mode.
    option token ''
    # Format example: 'http://192.168.1.100:8090' or 'https://hub.example.com'
    option hub_url ''
    
    # Load additional file systems (optional)
    # Add multiple mount points using 'list' syntax
    # list extra_filesystems '/mnt/sda1'
    # list extra_filesystems '/mnt/sdb1'
