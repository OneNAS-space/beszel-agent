+	for sName, sData := range ubusData {
+		unitName := sName + ".service"
+		currentUnits[unitName] = struct{}{}
+
+		pid := 0
+		isRunning := false
+		for _, inst := range sData.Instances {
+			if inst.Running && inst.Pid > 0 {
+				pid = inst.Pid
+				isRunning = true
+				break
+			}
 		}
-	} else {
-		return nil, err
-	}
 
